# Neon Postgres — use POOLED connection string (cold-start mitigation, eng D12)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Neon direct connection — used by pg_dump (pgBouncer/pooler blocks COPY protocol)
DATABASE_URL_DIRECT=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Cloudflare R2 (S3-compatible)
# R2_ENDPOINT format: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=entertainment-news
# Public URL base for serving images (custom domain or r2.dev URL)
R2_PUBLIC_URL=https://your-bucket.r2.dev

# TMDB API
TMDB_API_KEY=

# Public site URL (used for RSS feed autodiscovery and OG links)
NEXT_PUBLIC_SITE_URL=https://afterhours.film

# Pipeline health reporting — GHA workflows POST to /api/pipeline-health with this token
# Set the same value in: Vercel env vars + GitHub repo secrets (PIPELINE_HEALTH_SECRET)
PIPELINE_HEALTH_SECRET=
